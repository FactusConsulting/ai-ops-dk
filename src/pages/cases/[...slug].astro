---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const cases = (await getCollection("cases")).filter((c) => !c.data.draft);
  return cases.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const formatter = new Intl.DateTimeFormat("da-DK", { year: "numeric", month: "long" });
---

<BaseLayout title={entry.data.title} description={entry.data.summary} type="article">
  <article class="bg-white">
    <header class="border-b border-ink-100">
      <div class="container-page pt-16 md:pt-24 pb-12 max-w-4xl">
        <a href="/cases" class="inline-flex items-center gap-2 text-sm font-medium text-ink-500 hover:text-ink-900 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Alle cases
        </a>

        <div class="mt-8 flex items-center gap-2 flex-wrap">
          <span class="px-2.5 py-1 rounded-md bg-brand-50 text-brand-700 text-xs font-semibold uppercase tracking-wider">{entry.data.industry}</span>
          <span class="text-ink-400 text-sm">{entry.data.duration}</span>
          <span class="text-ink-300">·</span>
          <time class="text-ink-500 text-sm" datetime={entry.data.date.toISOString()}>{formatter.format(entry.data.date)}</time>
        </div>

        <h1 class="heading-1 mt-5">{entry.data.title}</h1>
        <p class="lead mt-6">{entry.data.summary}</p>

        {entry.data.outcomes.length > 0 && (
          <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-6 p-6 md:p-8 bg-ink-50 rounded-2xl border border-ink-100">
            {entry.data.outcomes.map((o) => (
              <div>
                <p class="font-display font-bold text-3xl md:text-4xl text-ink-900 leading-none">{o.value}</p>
                <p class="text-sm text-ink-600 mt-2">{o.label}</p>
              </div>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="container-page py-16 md:py-20 max-w-3xl">
      <div class="prose-content">
        <Content />
      </div>

      {entry.data.technologies.length > 0 && (
        <aside class="mt-16 pt-10 border-t border-ink-100">
          <p class="text-xs font-semibold uppercase tracking-wider text-ink-500">Teknologier</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {entry.data.technologies.map((t) => (
              <span class="px-3 py-1.5 rounded-md bg-ink-100 text-sm text-ink-800 font-medium">{t}</span>
            ))}
          </div>
        </aside>
      )}

      <div class="mt-16 p-8 md:p-10 rounded-2xl bg-gradient-to-br from-ink-900 to-brand-900 text-white">
        <h2 class="font-display text-2xl md:text-3xl font-bold tracking-tight">Har I et lignende behov?</h2>
        <p class="mt-3 text-ink-200">Lad os tage en uforpligtende snak om hvordan jeg kan hjælpe.</p>
        <a href="/#kontakt" class="mt-6 inline-flex items-center gap-2 bg-white text-ink-900 px-5 py-3 rounded-lg font-semibold text-sm hover:bg-ink-100 transition-colors">
          Kontakt mig
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose-content {
    color: var(--color-ink-700);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .prose-content h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 700;
    color: var(--color-ink-900);
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  .prose-content h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ink-900);
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
  }
  .prose-content p {
    margin-block: 1.25rem;
  }
  .prose-content ul {
    margin-block: 1.25rem;
    padding-left: 1.25rem;
    list-style: disc;
  }
  .prose-content ol {
    margin-block: 1.25rem;
    padding-left: 1.5rem;
    list-style: decimal;
  }
  .prose-content li {
    margin-block: 0.4rem;
  }
  .prose-content li::marker {
    color: var(--color-brand-600);
  }
  .prose-content strong {
    color: var(--color-ink-900);
    font-weight: 600;
  }
  .prose-content a {
    color: var(--color-brand-700);
    text-decoration: underline;
    text-decoration-color: var(--color-brand-200);
    text-underline-offset: 3px;
  }
  .prose-content a:hover {
    text-decoration-color: var(--color-brand-600);
  }
  .prose-content blockquote {
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    border-left: 3px solid var(--color-brand-600);
    background: var(--color-brand-50);
    color: var(--color-ink-800);
    font-style: italic;
    border-radius: 0 0.5rem 0.5rem 0;
  }
  .prose-content code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-ink-100);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    color: var(--color-ink-900);
  }
  .prose-content pre {
    background: var(--color-ink-900);
    color: var(--color-ink-100);
    padding: 1.25rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin-block: 1.5rem;
  }
  .prose-content pre code {
    background: transparent;
    padding: 0;
    color: inherit;
  }
</style>
