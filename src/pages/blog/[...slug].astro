---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((p) => !p.data.draft);
  return posts.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

import { site } from "../../config/site";

const { entry } = Astro.props;
const { Content } = await render(entry);
const formatter = new Intl.DateTimeFormat("da-DK", { year: "numeric", month: "long", day: "numeric" });

const postUrl = `${site.url}/blog/${entry.id}/`;
const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.date.toISOString(),
  ...(entry.data.updated && { dateModified: entry.data.updated.toISOString() }),
  author: {
    "@type": "Person",
    name: site.owner.name,
    url: site.owner.linkedin,
  },
  publisher: {
    "@type": "Organization",
    name: site.company.legalName,
    url: site.url,
  },
  mainEntityOfPage: postUrl,
  url: postUrl,
  inLanguage: "da-DK",
  ...(entry.data.tags.length > 0 && { keywords: entry.data.tags.join(", ") }),
};
const breadcrumbsSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Forside", item: site.url },
    { "@type": "ListItem", position: 2, name: "Blog", item: `${site.url}/blog/` },
    { "@type": "ListItem", position: 3, name: entry.data.title, item: postUrl },
  ],
};
---

<BaseLayout title={entry.data.title} description={entry.data.description} type="article">
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbsSchema)} />
  <article class="bg-white">
    <header class="border-b border-ink-100">
      <div class="container-page pt-16 md:pt-24 pb-10 max-w-3xl">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm font-medium text-ink-500 hover:text-ink-900 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Alle artikler
        </a>

        <div class="mt-8 flex items-center gap-2 flex-wrap text-sm text-ink-500">
          <span>Publiceret <time datetime={entry.data.date.toISOString()}>{formatter.format(entry.data.date)}</time></span>
          {entry.data.updated && (
            <>
              <span>·</span>
              <span class="text-brand-700">Sidst opdateret <time datetime={entry.data.updated.toISOString()}>{formatter.format(entry.data.updated)}</time></span>
            </>
          )}
          {entry.data.readingTime && (
            <>
              <span>·</span>
              <span>{entry.data.readingTime}</span>
            </>
          )}
        </div>

        <h1 class="heading-1 mt-4">{entry.data.title}</h1>
        <p class="lead mt-6">{entry.data.description}</p>

        {entry.data.tags.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-2">
            {entry.data.tags.map((t) => (
              <span class="px-3 py-1.5 rounded-md bg-brand-50 text-brand-700 text-xs font-medium">{t}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="container-page py-14 md:py-16 max-w-3xl">
      <div class="prose-content">
        <Content />
      </div>

      <div class="mt-16 p-8 rounded-2xl bg-ink-50 border border-ink-100">
        <h2 class="font-display text-xl font-bold text-ink-900">Står I med en lignende beslutning?</h2>
        <p class="mt-2 text-ink-600">Jeg hjælper gerne med at vurdere — første samtale er uforpligtende.</p>
        <a href="/#kontakt" class="mt-5 inline-flex items-center gap-2 btn-primary">
          Kontakt mig
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose-content {
    color: var(--color-ink-700);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .prose-content h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 700;
    color: var(--color-ink-900);
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  .prose-content h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ink-900);
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
  }
  .prose-content p { margin-block: 1.25rem; }
  .prose-content ul { margin-block: 1.25rem; padding-left: 1.25rem; list-style: disc; }
  .prose-content ol { margin-block: 1.25rem; padding-left: 1.5rem; list-style: decimal; }
  .prose-content li { margin-block: 0.4rem; }
  .prose-content li::marker { color: var(--color-brand-600); }
  .prose-content strong { color: var(--color-ink-900); font-weight: 600; }
  .prose-content em { font-style: italic; }
  .prose-content a {
    color: var(--color-brand-700);
    text-decoration: underline;
    text-decoration-color: var(--color-brand-200);
    text-underline-offset: 3px;
  }
  .prose-content a:hover { text-decoration-color: var(--color-brand-600); }
  .prose-content blockquote {
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    border-left: 3px solid var(--color-brand-600);
    background: var(--color-brand-50);
    color: var(--color-ink-800);
    font-style: italic;
    border-radius: 0 0.5rem 0.5rem 0;
  }
  .prose-content code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-ink-100);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    color: var(--color-ink-900);
  }
  .prose-content pre {
    background: var(--color-ink-900);
    color: var(--color-ink-100);
    padding: 1.25rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin-block: 1.5rem;
  }
  .prose-content pre code { background: transparent; padding: 0; color: inherit; }
</style>
