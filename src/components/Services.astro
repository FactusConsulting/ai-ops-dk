---
const services = [
  {
    icon: "compass",
    title: "AI-strategi og roadmap",
    body:
      "Konkret plan for hvor AI giver mening i jeres forretning — og hvor det ikke gør. Workshops, business cases og prioriteret roadmap I kan eksekvere på.",
    bullets: [
      "Use case discovery og kvalificering",
      "ROI-modeller og prioritering",
      "Make/buy/partner-vurdering",
    ],
  },
  {
    icon: "stack",
    title: "AI-infrastruktur",
    body:
      "Sikker, skalerbar platform for jeres AI-arbejde. Self-hosted, cloud eller hybrid — afhængigt af krav til data, latency og økonomi.",
    bullets: [
      "LLM hosting (Ollama, vLLM, llama.cpp)",
      "RAG-platforme og vektor-databaser",
      "GPU-kapacitet og omkostningsoptimering",
    ],
  },
  {
    icon: "wrench",
    title: "Implementering",
    body:
      "Hands-on udvikling af konkrete AI-løsninger der bringes i produktion. Fra første prototype til drift med monitoring og governance.",
    bullets: [
      "Custom assistenter og agenter",
      "RAG over interne dokumenter",
      "Workflow-automation med LLMs",
    ],
  },
  {
    icon: "shield",
    title: "Governance og sikkerhed",
    body:
      "Sørger for at jeres AI-anvendelse er compliant, dokumenteret og sikker. EU AI Act, GDPR og interne politikker bygget ind fra start.",
    bullets: [
      "EU AI Act gap-analyse",
      "Data- og prompt-governance",
      "Audit logs og adgangsstyring",
    ],
  },
  {
    icon: "graduation",
    title: "Oplæring af team",
    body:
      "Jeres folk skal kunne bære løsningerne videre. Skræddersyede forløb for udviklere, ledere og slutbrugere — uden buzzword-bingo.",
    bullets: [
      "Tekniske workshops for udviklere",
      "Beslutningsoplæg til ledelsen",
      "Brugertræning og adoption",
    ],
  },
  {
    icon: "stethoscope",
    title: "AI-sundhedstjek",
    body:
      "Eksisterende AI-projekt der ikke leverer som forventet? Jeg laver et struktureret review og giver konkrete anbefalinger til at få det på sporet.",
    bullets: [
      "Arkitektur- og kode-review",
      "Måling af kvalitet og kost",
      "Konkret action-plan",
    ],
  },
];

const iconPaths: Record<string, string> = {
  compass: "M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32l1.41-1.41M15 12l-3 6-3-6 3-3 3 3z",
  stack: "M12 3l9 4-9 4-9-4 9-4zm0 9l9-4M3 7l9 4m0 4l9-4-9 4-9-4 9 4zm0 4l9 4 9-4",
  wrench: "M14.7 6.3a4 4 0 015.66 5.66l-1.41-1.41-2.83 2.83-2.83-2.83 2.83-2.83-1.42-1.42zM3 17l8.5-8.5m6 6L20 17l-3 3-2.5-2.5",
  shield: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  graduation: "M22 10L12 5 2 10l10 5 10-5zm-4 3v5c-2 1.5-4 2.5-6 2.5s-4-1-6-2.5v-5",
  stethoscope: "M6 3v6a4 4 0 008 0V3M10 3v6m6 0v3a6 6 0 01-12 0M16 12a3 3 0 100 6 3 3 0 000-6z",
};
---

<section id="ydelser" class="section-y bg-ink-50/50 border-y border-ink-100">
  <div class="container-page">
    <div class="max-w-2xl">
      <span class="eyebrow">Ydelser</span>
      <h2 class="heading-2 mt-3">Hele rejsen — fra strategi til produktion.</h2>
      <p class="lead mt-5">
        Jeg arbejder typisk i korte, fokuserede forløb hvor leverancen er en konkret
        plan, et fungerende system eller et team der kan bære det videre. Ikke
        rapporter der ender i en skuffe.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {services.map((s) => (
        <article class="card group">
          <div class="flex items-center justify-center w-11 h-11 rounded-lg bg-brand-50 text-brand-700 group-hover:bg-brand-100 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[s.icon]} />
            </svg>
          </div>
          <h3 class="heading-3 mt-5">{s.title}</h3>
          <p class="prose-body mt-3 text-[0.95rem]">{s.body}</p>
          <ul class="mt-5 space-y-2">
            {s.bullets.map((b) => (
              <li class="flex items-start gap-2.5 text-sm text-ink-700">
                <svg class="w-4 h-4 mt-0.5 text-brand-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
