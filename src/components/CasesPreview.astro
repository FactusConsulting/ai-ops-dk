---
import { getCollection } from "astro:content";

const cases = (await getCollection("cases"))
  .filter((c) => !c.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<section id="cases" class="section-y bg-ink-50/50 border-y border-ink-100">
  <div class="container-page">
    <div class="flex items-end justify-between flex-wrap gap-6">
      <div class="max-w-2xl">
        <span class="eyebrow">Udvalgte cases</span>
        <h2 class="heading-2 mt-3">Resultater frem for slides.</h2>
        <p class="lead mt-5">
          Et par eksempler på opgaver jeg har løst. Detaljer er anonymiseret hvor nødvendigt.
        </p>
      </div>
      <a href="/cases" class="btn-secondary">
        Se alle cases
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {cases.map((c) => (
        <a href={`/cases/${c.id}`} class="card flex flex-col group">
          <div class="flex items-center gap-2">
            <span class="text-xs font-semibold uppercase tracking-wider text-brand-700">{c.data.industry}</span>
            <span class="text-ink-300">·</span>
            <span class="text-xs text-ink-500">{c.data.duration}</span>
          </div>
          <h3 class="heading-3 mt-3 group-hover:text-brand-700 transition-colors">{c.data.title}</h3>
          <p class="prose-body mt-3 text-[0.95rem] flex-1">{c.data.summary}</p>
          {c.data.outcomes && c.data.outcomes.length > 0 && (
            <div class="mt-5 pt-5 border-t border-ink-100 flex flex-wrap gap-x-5 gap-y-2">
              {c.data.outcomes.slice(0, 2).map((o) => (
                <div>
                  <p class="font-display font-bold text-xl text-ink-900">{o.value}</p>
                  <p class="text-xs text-ink-500 mt-0.5">{o.label}</p>
                </div>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </div>
</section>
